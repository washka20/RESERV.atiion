# Docker Compose dev порты хоста.
# Меняй здесь если порты заняты другими проектами.
# Сервисы внутри compose сети всегда общаются по внутренним портам (80, 5173, 5432, 6379, 9000, 9001).

NGINX_PORT=8080
FRONTEND_PORT=5273
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9500
MINIO_CONSOLE_PORT=9501

# Xdebug: off | debug | develop | coverage (подробнее в docker/php/xdebug.ini)
XDEBUG_MODE=off

# Host uid/gid для remap www-data в dev php-контейнере определяются автоматически
# через Makefile ($(id -u) / $(id -g)) и прокидываются как APP_UID/APP_GID.
# Ручная правка не требуется. Если запускаешь без make — либо export APP_UID/APP_GID,
# либо будут использованы defaults 1000/1000.
# См. docs/development/setup.md — "Permissions & multi-platform".
