<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Architecture">
            <directory>tests/Architecture</directory>
        </testsuite>
        <!--
        Директория tests/Smoke специально вынесена из testsuite. Запускается
        отдельным job (backend-seed-smoke) через `vendor/bin/pest tests/Smoke/`
        после `migrate:fresh + seed`. В обычных прогонах Unit/Feature не
        участвует: иначе паратест находит пустую БД после RefreshDatabase и
        проваливается на проверках заполненности.
        -->
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
        Testing environment defaults. DB_* приходят из окружения:
          - локально — docker-compose.test.yml (postgres-test testcontainer)
          - CI — GH Actions services + job env в .github/workflows/ci.yml
        Никакого SQLite: тесты идут против реальной PostgreSQL 17, как в prod.
        -->
        <env name="APP_ENV" value="testing"/>
        <!-- APP_KEY: намеренно low-entropy testing-only ключ (decodes в 'testing-reserv-atiion-keyxxxxxxx').
             Не используется в продакшене; CI/локальные тесты в tmpfs БД.
             GitGuardian: см. .gitguardian.yaml allowlist. -->
        <env name="APP_KEY" value="base64:dGVzdGluZy1yZXNlcnYtYXRpaW9uLWtleXh4eHh4eHg="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="JWT_SECRET" value="testing-secret-key-at-least-32-chars-long-for-sha256"/>
    </php>
</phpunit>
