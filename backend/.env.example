APP_NAME=RESERV.atiion
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=reservatiion
DB_USERNAME=app
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=reservatiion
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/reservatiion
AWS_USE_PATH_STYLE_ENDPOINT=true

# JWT (spec §11)
JWT_SECRET=
JWT_TTL=3600
JWT_REFRESH_TTL=2592000

MAIL_MAILER=log
